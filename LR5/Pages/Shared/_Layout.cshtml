<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Каталог товарів</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">Каталог товарів</a>
            <div class="navbar-nav">
                <a class="nav-link text-white" asp-page="/Index">Головна</a>
                <a class="nav-link text-white" asp-page="/Add">Додати</a>
                <a class="nav-link text-white" asp-page="/Search">Пошук</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <main>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-5 py-3 text-center text-muted">
        <small>Лабораторна робота №5 — Composite Pattern</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
