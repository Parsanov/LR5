@page
@model LR5.Pages.AddModel
@{
    ViewData["Title"] = "Додати елемент";
}

<h2 class="mb-4">Додати елемент</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="IsLeaf" id="isLeafInput" />

            <div class="mb-3">
                <label class="form-label">Тип елемента</label>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary @(!Model.IsLeaf ? "active" : "")"
                            id="btn-group" onclick="selectType(false)">
                        📁 Група
                    </button>
                    <button type="button" class="btn btn-outline-primary @(Model.IsLeaf ? "active" : "")"
                            id="btn-product" onclick="selectType(true)">
                        📄 Товар
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Назва</label>
                <input asp-for="Name" class="form-control" placeholder="Введіть назву" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParentId" class="form-label">Батьківська група</label>
                <select asp-for="ParentId" asp-items="Model.GroupOptions" class="form-select">
                    <option value="">— Корінь каталогу —</option>
                </select>
            </div>

            <div class="mb-3" id="priceField" style="display: @(Model.IsLeaf ? "block" : "none")">
                <label asp-for="Price" class="form-label">Ціна (₴)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Додати</button>
                <a asp-page="/Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>

    @if (Model.ParentItem != null)
    {
        <div class="col-md-4 offset-md-1">
            <div class="alert alert-secondary">
                <strong>Батьківський елемент:</strong><br />
                <code>@Model.ParentItem.AbsoluteCode</code> — @Model.ParentItem.Name
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function selectType(isLeaf) {
            document.getElementById('isLeafInput').value = isLeaf;
            document.getElementById('priceField').style.display = isLeaf ? 'block' : 'none';
            document.getElementById('btn-group').classList.toggle('active', !isLeaf);
            document.getElementById('btn-product').classList.toggle('active', isLeaf);
        }
    </script>
}