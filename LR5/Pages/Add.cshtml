@page
@model LR5.Pages.AddModel
@{
    ViewData["Title"] = "Додати елемент";
}

<style>
    .add-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        max-width: 800px;
    }

    @@media (max-width: 640px) {
        .add-layout { grid-template-columns: 1fr; }
    }

    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2rem;
    }

    .type-selector {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .type-card {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .type-card:hover { border-color: var(--muted); }
    .type-card.active-group { border-color: #7c3aed; background: rgba(124,58,237,0.08); }
    .type-card.active-product { border-color: var(--accent); background: rgba(0,229,255,0.06); }

    .type-icon { font-size: 1.5rem; display: block; margin-bottom: 6px; }
    .type-label {
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.06em;
    }

    .type-desc {
        font-size: 0.72rem;
        color: var(--muted);
        margin-top: 4px;
    }

    .price-field { display: none; }
    .price-field.visible { display: block; }

    .info-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        align-self: start;
    }

    .info-title {
        font-family: var(--mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .parent-badge {
        background: rgba(124,58,237,0.15);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 8px;
        padding: 10px 14px;
        font-family: var(--mono);
        font-size: 0.8rem;
        color: #a78bfa;
        margin-bottom: 1rem;
    }

    .hint {
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.6;
    }

    .hint li { margin-bottom: 4px; }
</style>

<div class="page-header">
    <h1 class="page-title">Додати елемент</h1>
    <span class="page-subtitle">до каталогу</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="add-layout">
    <div class="form-card">
        <div class="type-selector">
            <div class="type-card @(Model.IsLeaf ? "" : "active-group")" id="card-group" onclick="selectType(false)">
                <span class="type-icon">⬡</span>
                <div class="type-label" style="color:#a78bfa">ГРУПА</div>
                <div class="type-desc">Може містити підгрупи і товари</div>
            </div>
            <div class="type-card @(Model.IsLeaf ? "active-product" : "")" id="card-product" onclick="selectType(true)">
                <span class="type-icon">◈</span>
                <div class="type-label" style="color:var(--accent)">ТОВАР</div>
                <div class="type-desc">Лист ієрархії, має ціну</div>
            </div>
        </div>

        <form method="post">
            <input type="hidden" asp-for="IsLeaf" id="isLeafInput" />
            <input type="hidden" asp-for="ParentId" />

            <div class="form-group">
                <label asp-for="Name">Назва</label>
                <input asp-for="Name" placeholder="Наприклад: Intel Core i9" autocomplete="off" />
                <span asp-validation-for="Name" style="color:var(--danger);font-size:0.75rem;font-family:var(--mono)"></span>
            </div>

            <div class="form-group">
                <label for="parentSelect">Батьківська група</label>
                <select asp-for="ParentId" asp-items="Model.GroupOptions" id="parentSelect">
                    <option value="">— Корінь каталогу —</option>
                </select>
            </div>

            <div class="form-group price-field @(Model.IsLeaf ? "visible" : "")" id="priceField">
                <label asp-for="Price">Ціна (₴)</label>
                <input asp-for="Price" type="number" step="0.01" min="0" placeholder="0.00" />
                <span asp-validation-for="Price" style="color:var(--danger);font-size:0.75rem;font-family:var(--mono)"></span>
            </div>

            <div style="display:flex;gap:10px;margin-top:1.5rem">
                <button type="submit" class="btn btn-primary">＋ Додати</button>
                <a asp-page="/Index" class="btn btn-ghost">Скасувати</a>
            </div>
        </form>
    </div>

    <div class="info-card">
        <div class="info-title">📍 Батьківський елемент</div>

        @if (Model.ParentItem != null)
        {
            <div class="parent-badge">
                ⬡ @Model.ParentItem.AbsoluteCode — @Model.ParentItem.Name
            </div>
        }
        else
        {
            <div class="parent-badge" style="color:var(--muted);border-color:var(--border);background:transparent">
                Корінь / верхній рівень
            </div>
        }

        <ul class="hint">
            <li><strong style="color:var(--text)">Група</strong> — може містити інші групи або товари</li>
            <li><strong style="color:var(--text)">Товар</strong> — кінцевий елемент з ціною</li>
            <li>Коди присвоюються <strong style="color:var(--text)">автоматично</strong></li>
        </ul>
    </div>
</div>

@section Scripts {
<script>
    function selectType(isLeaf) {
        document.getElementById('isLeafInput').value = isLeaf;
        document.getElementById('priceField').classList.toggle('visible', isLeaf);
        document.getElementById('card-group').classList.remove('active-group');
        document.getElementById('card-product').classList.remove('active-product');
        if (isLeaf) {
            document.getElementById('card-product').classList.add('active-product');
        } else {
            document.getElementById('card-group').classList.add('active-group');
        }
    }
</script>
}
