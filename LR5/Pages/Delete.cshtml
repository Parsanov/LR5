@page "{id:int}"
@model LR5.Pages.DeleteModel
@{
    ViewData["Title"] = "Видалити";
}

<h2 class="mb-4">Видалення елемента</h2>

@if (Model.Item == null)
{
    <div class="alert alert-danger">Елемент не знайдено.</div>
    <a asp-page="/Index" class="btn btn-secondary">← Назад</a>
}
else
{
    <div class="card" style="max-width: 480px">
        <div class="card-body">
            <h5 class="card-title text-danger">Підтвердження видалення</h5>
            <p>Ви дійсно хочете видалити цей елемент?</p>

            <table class="table table-sm table-bordered mb-3">
                <tr><th>Код</th><td><code>@Model.Item.AbsoluteCode</code></td></tr>
                <tr><th>Назва</th><td>@Model.Item.Name</td></tr>
                <tr><th>Тип</th><td>@(Model.Item.IsLeaf ? "Товар" : "Група")</td></tr>
                @if (Model.Item.Price.HasValue)
                {
                    <tr><th>Ціна</th><td>@Model.Item.Price?.ToString("N0") ₴</td></tr>
                }
            </table>

            @if (!Model.Item.IsLeaf && Model.ChildrenCount > 0)
            {
                <div class="alert alert-warning">
                    ⚠ Група містить <strong>@Model.ChildrenCount</strong> елементів — вони також будуть видалені.
                </div>
            }

            <form method="post">
                <input type="hidden" name="id" value="@Model.Item.Id" />
                <button type="submit" class="btn btn-danger me-2">Так, видалити</button>
                <a asp-page="/Index" class="btn btn-secondary">Скасувати</a>
            </form>
        </div>
    </div>
}
