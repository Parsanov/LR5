@page
@model LR5.Pages.SearchModel
@{
    ViewData["Title"] = "Пошук";
}

<h2 class="mb-4">Пошук по каталогу</h2>

<form method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">Тип пошуку</label>
            <select name="mode" class="form-select">
                <option value="name" selected="@(Model.Mode != "code")">За назвою</option>
                <option value="code" selected="@(Model.Mode == "code")">За абсолютним кодом</option>
            </select>
        </div>
        <div class="col">
            <label class="form-label">Запит</label>
            <input name="q" value="@Model.Query" class="form-control"
                   placeholder="Введіть назву або код..." autocomplete="off" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Знайти</button>
        </div>
    </div>
</form>

@if (Model.Query != null)
{
    if (!Model.Results.Any())
    {
        <div class="alert alert-warning">Нічого не знайдено за запитом «@Model.Query».</div>
    }
    else
    {
        <p class="text-muted">Знайдено: <strong>@Model.Results.Count</strong> елементів</p>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Абсолютний код</th>
                    <th>Назва</th>
                    <th>Тип</th>
                    <th>Ціна, ₴</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results)
                {
                    <tr>
                        <td><code>@item.AbsoluteCode</code></td>
                        <td>@item.Name</td>
                        <td>
                            @if (!item.IsLeaf)
                            {
                                <span class="badge bg-secondary">Група</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Товар</span>
                            }
                        </td>
                        <td>@(item.Price.HasValue ? item.Price.Value.ToString("N0") : "—")</td>
                        <td>
                            <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
