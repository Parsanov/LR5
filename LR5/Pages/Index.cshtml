@page
@model LR5.Pages.IndexModel
@{
    ViewData["Title"] = "Каталог";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Каталог товарів</h2>
    <a asp-page="/Add" class="btn btn-success">+ Додати елемент</a>
</div>

@if (Model.Root == null || !Model.Root.Children.Any())
{
    <div class="alert alert-info">
        Каталог порожній. <a asp-page="/Add">Додайте перший елемент</a>.
    </div>
}
else
{
    <div class="mb-3 text-muted small">
        Груп: <strong>@Model.TotalGroups</strong> &nbsp;|&nbsp;
        Товарів: <strong>@Model.TotalProducts</strong>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Абсолютний код</th>
                <th>Відносний код</th>
                <th>Назва</th>
                <th>Тип</th>
                <th>Ціна, ₴</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.AllItems.OrderBy(i => i.AbsoluteCode))
            {
                <tr>
                    <td><code>@item.AbsoluteCode</code></td>
                    <td><code>@item.RelativeCode</code></td>
                    <td style="padding-left: @((item.AbsoluteCode.Length / 2 - 1) * 20 + 8)px">
                        @if (!item.IsLeaf)
                        {
                            <strong>📁 @item.Name</strong>
                        }
                        else
                        {
                            <span>📄 @item.Name</span>
                        }
                    </td>
                    <td>
                        @if (!item.IsLeaf)
                        {
                            <span class="badge bg-secondary">Група</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Товар</span>
                        }
                    </td>
                    <td>@(item.Price.HasValue ? item.Price.Value.ToString("N0") : "—")</td>
                    <td>
                        @if (!item.IsLeaf)
                        {
                            <a asp-page="/Add" asp-route-parentId="@item.Id" class="btn btn-sm btn-outline-success me-1">+</a>
                        }
                        <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
